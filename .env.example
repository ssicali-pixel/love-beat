# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# HTTP port
PORT=3000

# Comma-separated allowed cross-origin origins (e.g. https://southcallingfestival.it).
# Leave empty to allow same-origin only (recommended — the SPA is served by this server).
CORS_ORIGINS=

# Token required to open /dashboard and the analytics read endpoints.
# Leave empty ONLY for local dev; always set a long random value in production.
DASHBOARD_TOKEN=

# Set to 1 only when running behind a trusted reverse proxy / load balancer that
# sets X-Forwarded-For. Leaving it 0 prevents client IP spoofing of the rate limiter.
TRUST_PROXY=0

# SMTP — only needed if you wire nodemailer to actually send contact/newsletter emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO=
